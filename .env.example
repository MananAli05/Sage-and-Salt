# Groq API Configuration (for Llama 70B & text extraction)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-70b-8192

# Whisper API (OpenAI for Urdu speech-to-text)
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL=large-v3

# Base URL for webhooks
BASE_URL=https://sage-and-salt.vercel.app

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Restaurant Info
RESTAURANT_NAME=Sage & Salt
RESTAURANT_PHONE=+92-123-456-7890
RESTAURANT_ADDRESS=Your Restaurant Address

# Payment Methods
PAYMENT_ONLINE_ENABLED=true
PAYMENT_COD_ENABLED=true

# Delivery Settings
DEFAULT_DELIVERY_TIME=30
DEFAULT_DELIVERY_CHARGE=150
